.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
.project
.settings/
.classpath
.factorypath

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/
.tox/
.coverage
htmlcov/

# Testing
coverage/
.nyc_output/

